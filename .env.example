# Copy this file to .env and fill in your values. Never commit .env to git.

# Paste the entire service_account.json content as a single-line JSON string
GDRIVE_CREDENTIALS_JSON_CONTENT={"type":"service_account","project_id":"..."}

# Comma-separated allowed origins for CORS
# Use your Cloudflare Tunnel URL or * for local testing
CORS_ORIGINS=https://your-tunnel.trycloudflare.com
