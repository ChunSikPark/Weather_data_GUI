# Team Overbye Weather Data API — Environment Variables
# Copy to .env and fill in values

# ─── Google Drive Credentials ───────────────────────────────────────────────
# Path to service account JSON key file
# Service account: drive-script-bot@pydrive2-461721.iam.gserviceaccount.com
GDRIVE_CREDENTIALS_JSON=/app/credentials/service_account.json

# HOST-side path to the credentials directory (for Docker volume mount)
GDRIVE_CREDENTIALS_HOST_DIR=./credentials

# ─── Google Drive Folder IDs ─────────────────────────────────────────────────
# These default to known values in catalog.py but can be overridden here
GDRIVE_HRRR_FORECAST_FOLDER_ID=1yuEH5020Nh-Km5_PvYfmVpWTQIhzI1Iz
GDRIVE_HRRR_HISTORY_FOLDER_ID=1Uc-tuSPEnh7rJzC3nFvxndFvULrsNe-U
GDRIVE_HRRR_HISTORY_ARCHIVE_FOLDER_ID=1_govjuY2WV0TqHp_7PwVVtrGPCDU-I9v
GDRIVE_NOAA_FOLDER_ID=1wICJMuO0MRopG3hpPFt7MzFmx5M33v4R
GDRIVE_NOAA_ARCHIVE_FOLDER_ID=1TTa-bDV88sSf4strSW649UHPRddMHJtr
GDRIVE_ERA5_QUARTERLY_FOLDER_ID=12U8PNHHGIxCy8_GRzsF2KxZ4GneMWy6h
GDRIVE_ERA5_FOLDER_ID=1jN1NP3b5Nby-gpy5w1rqe2cgctESxqO-
GDRIVE_ERA5_ARCHIVE_FOLDER_ID=1PD_y38k6x8HjDR8Wv-15NsZ6pdZ9pVPz

# ─── Pipeline Status ──────────────────────────────────────────────────────────
# Path INSIDE the container where alert_state.json will be mounted
ALERT_STATE_PATH=/app/config/alert_state.json

# Path on the HOST machine to alert_state.json
# (from weather_auto/notify_bot/config/alert_state.json on the Docker host)
ALERT_STATE_HOST_PATH=/path/to/weather_auto/notify_bot/config/alert_state.json

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
# Example: https://weather.yoursite.com,https://yoursite.com
CORS_ORIGINS=*

# ─── Development ─────────────────────────────────────────────────────────────
# Set to true to enable debug logging
DEBUG=false
